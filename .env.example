# AMD-IMS Environment Configuration

# App
APP_NAME=AMD Internal Management System
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
DEBUG=True

# Database (SQLite mặc định, đổi sang MySQL khi deploy)
DATABASE_URL=sqlite:///./amd_ims.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/amd_ims

# AI Import — chọn 1 trong 2
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20
